---
const year = new Date().getFullYear();

const builtWith = [
  { name: 'Astro', url: 'https://astro.build' },
  { name: 'TypeScript', url: 'https://typescriptlang.org' },
  { name: 'Vercel', url: 'https://tejansree21-github-io.vercel.app/' },
  { name: 'JetBrains Mono', url: 'https://www.jetbrains.com/lp/mono/' },
];

const footerLinks = [
  { href: '/resume/', label: 'Resume' },
  { href: '/contact/', label: 'Contact' },
  { href: '/uses/', label: 'Uses' },
  { href: '/guestbook/', label: 'Guestbook' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<footer class="footer">
  <div class="container">
    <!-- Built With -->
    <div class="footer__built-with">
      <span class="footer__label">built with</span>
      <div class="footer__tech">
        {builtWith.map((tech) => (
          <a href={tech.url} target="_blank" rel="noopener" class="footer__tech-item">{tech.name}</a>
        ))}
      </div>
    </div>

    <!-- Footer nav -->
    <div class="footer__links">
      {footerLinks.map((link) => (
        <a href={link.href} class="footer__link">{link.label}</a>
      ))}
    </div>

    <!-- Badges -->
    <div class="footer__badges">
      <a href="https://github.com/tejansree21/tejansree21.github.io" target="_blank" rel="noopener" class="footer__badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        open source
      </a>
      <span class="footer__badge footer__badge--green">
        <span class="footer__lighthouse-dot"></span>
        lighthouse 95+
      </span>
    </div>

    <!-- Status + Copyright -->
    <div class="footer__bottom">
      <div class="footer__status">
        <span class="status-dot"></span>
        <span>available for opportunities</span>
      </div>
      <p class="footer__copy">
        &copy; {year} tejan sree challa
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
    margin-top: 4rem;
  }

  .footer__built-with {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .footer__label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .footer__tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .footer__tech-item {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
  }

  .footer__tech-item:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .footer__links {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__link:hover {
    color: var(--accent);
  }

  .footer__badges {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .footer__badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
  }

  .footer__badge:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .footer__badge--green {
    color: var(--accent);
    border-color: rgba(0, 229, 160, 0.3);
  }

  .footer__lighthouse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .footer__bottom {
    text-align: center;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .footer__status {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .footer__copy {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
</style>
