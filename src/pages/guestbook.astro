---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Guestbook — Tejan Sree Challa">
  <Header />
  <main class="container">
    <section class="page-header">
      <div class="section-label">// guestbook</div>
      <h1 class="page-title">Leave a message</h1>
      <p class="page-desc">Say hello, drop feedback, or just sign the guestbook. Messages are stored locally in your browser.</p>
    </section>

    <div class="guestbook" id="guestbook">
      <div class="guestbook__form">
        <input type="text" id="gb-name" class="guestbook__input" placeholder="Your name" maxlength="50" />
        <textarea id="gb-message" class="guestbook__textarea" placeholder="Your message..." maxlength="280" rows="3"></textarea>
        <button id="gb-submit" class="guestbook__btn">Sign guestbook →</button>
      </div>

      <div class="guestbook__entries" id="gb-entries">
        <div class="guestbook__empty" id="gb-empty">No entries yet. Be the first to sign!</div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-title { font-size: 32px; font-weight: 600; margin-bottom: 8px; }
  .page-desc { color: var(--muted); font-size: 15px; }

  .guestbook { max-width: 600px; margin-top: 2rem; }

  .guestbook__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 2rem;
  }

  .guestbook__input,
  .guestbook__textarea {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .guestbook__input:focus,
  .guestbook__textarea:focus {
    border-color: var(--accent);
  }

  .guestbook__textarea {
    resize: vertical;
    min-height: 80px;
  }

  .guestbook__btn {
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 10px 24px;
    border: 1px solid var(--accent);
    border-radius: 6px;
    color: var(--accent);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
    align-self: flex-start;
  }

  .guestbook__btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .guestbook__entries {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .guestbook__empty {
    color: var(--muted);
    font-size: 13px;
    font-style: italic;
  }
</style>

<script>
  function setupGuestbook() {
    const nameInput = document.getElementById('gb-name') as HTMLInputElement;
    const msgInput = document.getElementById('gb-message') as HTMLTextAreaElement;
    const submit = document.getElementById('gb-submit');
    const entries = document.getElementById('gb-entries');
    const empty = document.getElementById('gb-empty');
    if (!nameInput || !msgInput || !submit || !entries || !empty) return;

    let guestbook = [];
    try { guestbook = JSON.parse(localStorage.getItem('guestbook') || '[]'); } catch {}

    function renderEntries() {
      const entryEls = entries.querySelectorAll('.gb-entry');
      entryEls.forEach(el => el.remove());

      if (guestbook.length === 0) {
        empty.style.display = 'block';
        return;
      }
      empty.style.display = 'none';

      guestbook.forEach((entry) => {
        const el = document.createElement('div');
        el.className = 'gb-entry';
        el.style.cssText = 'background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:14px 16px;';
        el.innerHTML = `
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
            <strong style="font-size:14px;color:var(--accent);">${entry.name}</strong>
            <span style="font-family:var(--font-mono);font-size:10px;color:var(--muted);">${entry.date}</span>
          </div>
          <p style="font-size:13px;color:var(--muted);line-height:1.5;">${entry.message}</p>
        `;
        entries.appendChild(el);
      });
    }

    submit.addEventListener('click', () => {
      const name = nameInput.value.trim();
      const message = msgInput.value.trim();
      if (!name || !message) return;

      const entry = {
        name: name.replace(/</g, '&lt;').replace(/>/g, '&gt;'),
        message: message.replace(/</g, '&lt;').replace(/>/g, '&gt;'),
        date: new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      };

      guestbook.unshift(entry);
      localStorage.setItem('guestbook', JSON.stringify(guestbook));
      nameInput.value = '';
      msgInput.value = '';
      renderEntries();
    });

    renderEntries();
  }

  setupGuestbook();
  document.addEventListener('astro:after-swap', setupGuestbook);
</script>
