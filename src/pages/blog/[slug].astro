---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} — Tejan Sree Challa`}>
  <Header />
  <main class="container">
    <article style="padding:2rem 0;max-width:700px">
      <a href="/blog/" style="font-family:var(--font-mono);font-size:12px;color:var(--muted);text-decoration:none;display:inline-block;margin-bottom:2rem">← back to blog</a>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px"><span style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">{post.data.date.toISOString().split('T')[0]}</span>{post.data.tags.map((tag: string) => (<span class="tag" style="font-size:10px;padding:3px 10px">{tag}</span>))}</div>
      <h1 style="font-size:32px;font-weight:600;margin-bottom:12px;line-height:1.2">{post.data.title}</h1>
      <p style="font-size:16px;color:var(--muted);line-height:1.6;margin-bottom:3rem">{post.data.description}</p>
      <div class="prose"><Content /></div>
    </article>
  </main>
  <Footer />
</BaseLayout>
