---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog');
const posts = allPosts.filter((p) => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog — Tejan Sree Challa">
  <Header />
  <main class="container">
    <section class="page-header"><div class="section-label">// blog</div><h1 class="page-title">Writing & thoughts</h1><p class="page-desc">Tutorials, project deep-dives, and things I've learned.</p></section>
    <div class="blog-list">{posts.map((post) => (<a href={`/blog/${post.id}/`} class="blog-item"><div><h3 class="blog-item__title">{post.data.title}</h3><p class="blog-item__desc">{post.data.description}</p><div class="blog-item__tags">{post.data.tags.map((tag: string) => (<span class="blog-item__tag">{tag}</span>))}</div></div><span class="blog-item__date">{post.data.date.toISOString().split('T')[0]}</span></a>))}</div>
  </main>
  <Footer />
</BaseLayout>
<style>.page-header{padding:3rem 0 2rem}.page-title{font-size:32px;font-weight:600;margin-bottom:8px}.page-desc{color:var(--muted);font-size:15px}.blog-list{margin-top:2rem}.blog-item{display:flex;justify-content:space-between;align-items:flex-start;padding:20px 0;border-bottom:1px solid var(--border);text-decoration:none;color:var(--text);transition:all .2s}.blog-item:hover{padding-left:8px}.blog-item:hover .blog-item__title{color:var(--accent)}.blog-item__title{font-size:16px;font-weight:500;margin-bottom:4px;transition:color .2s}.blog-item__desc{font-size:13px;color:var(--muted);margin-bottom:8px;max-width:550px}.blog-item__tags{display:flex;gap:6px}.blog-item__tag{font-family:var(--font-mono);font-size:10px;padding:3px 10px;border-radius:12px;background:rgba(124,77,255,.1);color:var(--accent3)}.blog-item__date{font-family:var(--font-mono);font-size:11px;color:var(--muted);white-space:nowrap;margin-left:20px;margin-top:4px}@media(max-width:600px){.blog-item{flex-direction:column;gap:8px}.blog-item__date{margin-left:0}}</style>
