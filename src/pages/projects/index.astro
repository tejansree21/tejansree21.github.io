---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects — Tejan Sree Challa">
  <Header />
  <main class="container">
    <section class="page-header">
      <div class="section-label">// projects</div>
      <h1 class="page-title">Things I've built</h1>
      <p class="page-desc">A collection of projects — big experiments, small tools, and everything in between.</p>
    </section>

    <div class="projects-grid">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          featured={project.data.featured}
          github={project.data.github}
          live={project.data.live}
          slug={project.id}
        />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
  }

  .page-title {
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .page-desc {
    color: var(--muted);
    font-size: 15px;
    max-width: 500px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 2rem;
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
