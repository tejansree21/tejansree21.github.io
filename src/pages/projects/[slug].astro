---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Tejan Sree Challa`}>
  <Header />
  <main class="container">
    <article class="project-page">
      <a href="/projects/" class="back-link">← back to projects</a>

      <div class="project-page__header">
        <div class="section-label">{project.data.featured ? '★ FEATURED PROJECT' : '// PROJECT'}</div>
        <h1 class="project-page__title">{project.data.title}</h1>
        <p class="project-page__desc">{project.data.description}</p>

        <div class="project-page__meta">
          <div class="project-page__tags">
            {project.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <div class="project-page__links">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noopener" class="social-btn">
                GitHub →
              </a>
            )}
            {project.data.live && (
              <a href={project.data.live} target="_blank" rel="noopener" class="social-btn">
                Live Demo →
              </a>
            )}
          </div>
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding: 2rem 0;
    max-width: 700px;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .project-page__header {
    margin-bottom: 3rem;
  }

  .project-page__title {
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .project-page__desc {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .project-page__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
  }

  .project-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .project-page__links {
    display: flex;
    gap: 8px;
  }
</style>
