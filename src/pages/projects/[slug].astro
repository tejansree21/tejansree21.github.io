---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={`${project.data.title} — Tejan Sree Challa`}>
  <Header />
  <main class="container">
    <article style="padding:2rem 0;max-width:700px">
      <a href="/projects/" style="font-family:var(--font-mono);font-size:12px;color:var(--muted);text-decoration:none;display:inline-block;margin-bottom:2rem">← back to projects</a>
      <div class="section-label">{project.data.featured ? '★ FEATURED PROJECT' : '// PROJECT'}</div>
      <h1 style="font-size:32px;font-weight:600;margin-bottom:12px">{project.data.title}</h1>
      <p style="font-size:16px;color:var(--muted);line-height:1.6;margin-bottom:20px">{project.data.description}</p>
      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px">{project.data.tags.map((tag: string) => (<span class="tag">{tag}</span>))}</div>
      <div style="display:flex;gap:8px;margin-bottom:2rem">
        {project.data.github && <a href={project.data.github} target="_blank" rel="noopener" class="social-btn">GitHub →</a>}
        {project.data.live && <a href={project.data.live} target="_blank" rel="noopener" class="social-btn">Live Demo →</a>}
      </div>
      <div class="prose"><Content /></div>
    </article>
  </main>
  <Footer />
</BaseLayout>
