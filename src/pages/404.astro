---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Page Not Found">
  <Header />
  <main class="container">
    <section class="not-found">
      <div class="not-found__code">404</div>
      <div class="not-found__terminal">
        <span class="not-found__prompt">$ cd /page-you-wanted</span>
        <span class="not-found__error">bash: cd: /page-you-wanted: No such file or directory</span>
      </div>
      <h1 class="not-found__title">Page not found</h1>
      <p class="not-found__text">The page you're looking for doesn't exist, was removed, or you made a typo in the URL.</p>
      <div class="not-found__actions">
        <a href="/" class="social-btn">← Go home</a>
        <a href="/projects/" class="social-btn">View projects</a>
        <a href="/blog/" class="social-btn">Read blog</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 0 4rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .not-found__code {
    font-family: var(--font-mono);
    font-size: 100px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent), var(--accent3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .not-found__terminal {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 2rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .not-found__prompt {
    color: var(--accent);
  }

  .not-found__error {
    color: #ff5f57;
  }

  .not-found__title {
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .not-found__text {
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .not-found__actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
