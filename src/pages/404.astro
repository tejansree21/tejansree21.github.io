---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="404 — Page Not Found"><Header />
<main class="container">
  <section style="text-align:center;padding:6rem 0 4rem;max-width:500px;margin:0 auto">
    <div style="font-family:var(--font-mono);font-size:100px;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:1.5rem">404</div>
    <div style="background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-bottom:2rem;text-align:left;font-family:var(--font-mono);font-size:12px;display:flex;flex-direction:column;gap:6px"><span style="color:var(--accent)">$ cd /page-you-wanted</span><span style="color:#ff5f57">bash: cd: /page-you-wanted: No such file or directory</span></div>
    <h1 style="font-size:24px;font-weight:500;margin-bottom:8px">Page not found</h1>
    <p style="color:var(--muted);font-size:14px;margin-bottom:2rem;line-height:1.6">The page you're looking for doesn't exist or was removed.</p>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap"><a href="/" class="social-btn">← Go home</a><a href="/projects/" class="social-btn">View projects</a><a href="/blog/" class="social-btn">Read blog</a></div>
  </section>
</main><Footer /></BaseLayout>
