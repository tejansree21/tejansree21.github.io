---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Resume — Tejan Sree Challa">
  <Header />
  <main class="container">
    <section class="page-header">
      <div class="section-label">// resume</div>
      <h1 class="page-title">Resume</h1>
      <p class="page-desc">My experience, education, and skills at a glance.</p>
    </section>

    <div class="resume">
      <!-- Download bar -->
      <div class="resume__download">
        <div>
          <h3 class="resume__download-title">Tejan Sree Challa — Resume</h3>
          <p class="resume__download-sub">Last updated April 2026</p>
        </div>
        <a href="/resume.pdf" download class="resume-btn">Download PDF ↓</a>
      </div>

      <!-- Education -->
      <div class="resume__section">
        <h2 class="resume__heading">Education</h2>
        <div class="resume__item">
          <div class="resume__item-header">
            <div>
              <h3 class="resume__item-title">National College of Ireland</h3>
              <p class="resume__item-sub">BSc (Hons) in Computing</p>
            </div>
            <span class="resume__item-date">2023 — Present</span>
          </div>
          <p class="resume__item-desc">
            Studying computer science with focus on software development, data structures, and machine learning.
          </p>
        </div>
      </div>

      <!-- Experience -->
      <div class="resume__section">
        <h2 class="resume__heading">Experience</h2>
        <div class="resume__item">
          <div class="resume__item-header">
            <div>
              <h3 class="resume__item-title">Your Role Title</h3>
              <p class="resume__item-sub">Company Name</p>
            </div>
            <span class="resume__item-date">2024 — Present</span>
          </div>
          <p class="resume__item-desc">
            Describe what you did, what technologies you used, and what impact you made. Replace this with your actual experience.
          </p>
        </div>
        <div class="resume__item">
          <div class="resume__item-header">
            <div>
              <h3 class="resume__item-title">Another Role</h3>
              <p class="resume__item-sub">Another Company</p>
            </div>
            <span class="resume__item-date">2023 — 2024</span>
          </div>
          <p class="resume__item-desc">
            Add your previous roles here. You can add as many sections as you need.
          </p>
        </div>
      </div>

      <!-- Skills -->
      <div class="resume__section">
        <h2 class="resume__heading">Skills</h2>
        <div class="resume__skills">
          <div class="resume__skill-group">
            <h4 class="resume__skill-label">Languages</h4>
            <div class="resume__skill-tags">
              <span class="tag tag--accent">TypeScript</span>
              <span class="tag tag--accent">JavaScript</span>
              <span class="tag tag--purple">Python</span>
              <span class="tag">HTML/CSS</span>
              <span class="tag">SQL</span>
            </div>
          </div>
          <div class="resume__skill-group">
            <h4 class="resume__skill-label">Frameworks & Tools</h4>
            <div class="resume__skill-tags">
              <span class="tag tag--accent">React</span>
              <span class="tag tag--accent">Next.js</span>
              <span class="tag tag--blue">Node.js</span>
              <span class="tag tag--blue">Supabase</span>
              <span class="tag">Astro</span>
              <span class="tag">Tailwind CSS</span>
              <span class="tag">Git</span>
            </div>
          </div>
          <div class="resume__skill-group">
            <h4 class="resume__skill-label">Areas</h4>
            <div class="resume__skill-tags">
              <span class="tag tag--purple">Machine Learning</span>
              <span class="tag">Full-Stack Dev</span>
              <span class="tag">REST APIs</span>
              <span class="tag">UI/UX</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Certifications (optional) -->
      <div class="resume__section">
        <h2 class="resume__heading">Certifications & Awards</h2>
        <div class="resume__item">
          <div class="resume__item-header">
            <div>
              <h3 class="resume__item-title">Add your certifications here</h3>
              <p class="resume__item-sub">Issuing Organization</p>
            </div>
            <span class="resume__item-date">2025</span>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-title { font-size: 32px; font-weight: 600; margin-bottom: 8px; }
  .page-desc { color: var(--muted); font-size: 15px; }

  .resume { max-width: 700px; margin-top: 1rem; }

  .resume__download {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 16px;
  }

  .resume__download-title { font-size: 15px; font-weight: 500; }
  .resume__download-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .resume-btn {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 10px 24px;
    border: 1px solid var(--accent);
    border-radius: 6px;
    color: var(--accent);
    background: transparent;
    text-decoration: none;
    transition: all 0.2s;
  }

  .resume-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .resume__section {
    margin-bottom: 2.5rem;
  }

  .resume__heading {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .resume__item {
    margin-bottom: 20px;
  }

  .resume__item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
    gap: 16px;
  }

  .resume__item-title { font-size: 15px; font-weight: 500; }
  .resume__item-sub { font-size: 13px; color: var(--muted); margin-top: 2px; }

  .resume__item-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }

  .resume__item-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .resume__skills { display: flex; flex-direction: column; gap: 16px; }

  .resume__skill-group {}

  .resume__skill-label {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 8px;
    font-weight: 400;
  }

  .resume__skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (max-width: 600px) {
    .resume__item-header { flex-direction: column; gap: 4px; }
    .resume__download { flex-direction: column; text-align: center; }
  }
</style>
