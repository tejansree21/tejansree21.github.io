---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Uses — Tejan Sree Challa"><Header />
<main class="container">
  <section style="padding:3rem 0 2rem"><div class="section-label">// uses</div><h1 style="font-size:32px;font-weight:600;margin-bottom:8px">What I use</h1><p style="color:var(--muted);font-size:15px">My daily tools, hardware, and software. Inspired by <a href="https://uses.tech" target="_blank" rel="noopener" style="color:var(--accent)">uses.tech</a>.</p></section>
  <div style="max-width:700px;margin-top:1rem">
    <div style="margin-bottom:2.5rem"><h2 style="font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)">Editor & Terminal</h2><ul style="list-style:none;padding:0"><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">VS Code</strong> — Primary editor with dark theme.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">Windows Terminal</strong> — PowerShell and Git Bash.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0"><strong style="color:var(--text)">GitHub Copilot</strong> — AI pair programming via Student Pack.</li></ul></div>
    <div style="margin-bottom:2.5rem"><h2 style="font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)">Development</h2><ul style="list-style:none;padding:0"><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">Astro</strong> — For this portfolio and content sites.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">Next.js / React</strong> — For full-stack apps.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">Supabase</strong> — Backend, auth, real-time DB.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0"><strong style="color:var(--text)">Git + GitHub</strong> — Version control and CI/CD.</li></ul></div>
    <div style="margin-bottom:2.5rem"><h2 style="font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)">Productivity</h2><ul style="list-style:none;padding:0"><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0;border-bottom:1px solid var(--border)"><strong style="color:var(--text)">Claude</strong> — AI assistant for coding, writing, brainstorming.</li><li style="font-size:14px;color:var(--muted);line-height:1.6;padding:8px 0"><strong style="color:var(--text)">Notion</strong> — Notes, planning, project management.</li></ul></div>
  </div>
</main><Footer /></BaseLayout>
