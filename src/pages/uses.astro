---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Uses — Tejan Sree Challa">
  <Header />
  <main class="container">
    <section class="page-header">
      <div class="section-label">// uses</div>
      <h1 class="page-title">What I use</h1>
      <p class="page-desc">My daily tools, hardware, and software. Inspired by <a href="https://uses.tech" target="_blank" rel="noopener">uses.tech</a>.</p>
    </section>

    <div class="uses">
      <div class="uses__section">
        <h2 class="uses__heading">Editor & Terminal</h2>
        <ul class="uses__list">
          <li><strong>VS Code</strong> — My primary editor. Dark theme, minimal extensions.</li>
          <li><strong>JetBrains IDEs</strong> — IntelliJ IDEA and PyCharm for larger projects (free via Student Pack).</li>
          <li><strong>Windows Terminal</strong> — With PowerShell and Git Bash.</li>
          <li><strong>GitHub Copilot</strong> — AI pair programming via Student Pack.</li>
        </ul>
      </div>

      <div class="uses__section">
        <h2 class="uses__heading">Development</h2>
        <ul class="uses__list">
          <li><strong>Astro</strong> — For this portfolio and content-heavy sites.</li>
          <li><strong>Next.js</strong> — For full-stack React apps.</li>
          <li><strong>Supabase</strong> — Backend, auth, and real-time database.</li>
          <li><strong>Tailwind CSS</strong> — Utility-first styling.</li>
          <li><strong>Git + GitHub</strong> — Version control and CI/CD.</li>
          <li><strong>Node.js</strong> — Runtime for JS/TS projects.</li>
        </ul>
      </div>

      <div class="uses__section">
        <h2 class="uses__heading">Design & Productivity</h2>
        <ul class="uses__list">
          <li><strong>Figma</strong> — UI design and wireframing.</li>
          <li><strong>Notion</strong> — Notes, project management, and planning.</li>
          <li><strong>Claude</strong> — AI assistant for coding, writing, and brainstorming.</li>
          <li><strong>Canva</strong> — Quick graphics and social media assets.</li>
        </ul>
      </div>

      <div class="uses__section">
        <h2 class="uses__heading">Hardware</h2>
        <ul class="uses__list">
          <li><strong>Laptop</strong> — Update with your actual laptop model.</li>
          <li><strong>Monitor</strong> — Update with your monitor if any.</li>
          <li><strong>Keyboard</strong> — Update with your keyboard.</li>
        </ul>
      </div>

      <div class="uses__section">
        <h2 class="uses__heading">Browser & Extensions</h2>
        <ul class="uses__list">
          <li><strong>Chrome / Edge</strong> — Primary browser.</li>
          <li><strong>React DevTools</strong> — For debugging React apps.</li>
          <li><strong>uBlock Origin</strong> — Ad blocking.</li>
        </ul>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-title { font-size: 32px; font-weight: 600; margin-bottom: 8px; }
  .page-desc { color: var(--muted); font-size: 15px; }
  .page-desc a { color: var(--accent); }

  .uses { max-width: 700px; margin-top: 1rem; }

  .uses__section { margin-bottom: 2.5rem; }

  .uses__heading {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .uses__list {
    list-style: none;
    padding: 0;
  }

  .uses__list li {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }

  .uses__list li:last-child {
    border-bottom: none;
  }

  .uses__list strong {
    color: var(--text);
    font-weight: 500;
  }
</style>
