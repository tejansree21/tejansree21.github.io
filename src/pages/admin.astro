---
// No layout - standalone admin page
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin — Tejan's Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0f; --bg2: #12121a; --bg3: #1a1a26;
      --accent: #00e5a0; --accent2: #00b8d4; --accent3: #7c4dff;
      --text: #e8e8f0; --muted: #8888a0; --border: #2a2a3a;
      --font-body: 'Outfit', sans-serif; --font-mono: 'JetBrains Mono', monospace;
      --danger: #ff5f57; --success: #28c840; --warning: #febc2e;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:var(--bg); color:var(--text); font-family:var(--font-body); min-height:100vh; }

    /* Login */
    .login { display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .login__box { background:var(--bg2); border:1px solid var(--border); border-radius:12px; padding:40px; width:360px; text-align:center; }
    .login__logo { font-family:var(--font-mono); font-size:24px; margin-bottom:8px; }
    .login__logo span { color:var(--accent); }
    .login__sub { font-size:13px; color:var(--muted); margin-bottom:24px; }
    .login__input { width:100%; padding:12px 16px; background:var(--bg3); border:1px solid var(--border); border-radius:8px; color:var(--text); font-family:var(--font-mono); font-size:18px; text-align:center; letter-spacing:12px; outline:none; }
    .login__input:focus { border-color:var(--accent); }
    .login__btn { width:100%; margin-top:16px; padding:12px; background:var(--accent); color:var(--bg); border:none; border-radius:8px; font-family:var(--font-mono); font-size:13px; cursor:pointer; font-weight:500; }
    .login__btn:hover { opacity:0.9; }
    .login__error { color:var(--danger); font-size:12px; margin-top:12px; display:none; }

    /* Admin layout */
    .admin { display:none; max-width:900px; margin:0 auto; padding:2rem 1.5rem; }
    .admin__header { display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; padding-bottom:1rem; border-bottom:1px solid var(--border); }
    .admin__title { font-family:var(--font-mono); font-size:14px; color:var(--accent); }
    .admin__logout { font-family:var(--font-mono); font-size:11px; color:var(--muted); background:none; border:1px solid var(--border); border-radius:6px; padding:6px 14px; cursor:pointer; }
    .admin__logout:hover { color:var(--danger); border-color:var(--danger); }

    /* Tabs */
    .tabs { display:flex; gap:0; margin-bottom:2rem; border-bottom:1px solid var(--border); overflow-x:auto; }
    .tab { font-family:var(--font-mono); font-size:12px; padding:10px 20px; color:var(--muted); cursor:pointer; border-bottom:2px solid transparent; white-space:nowrap; background:none; border-top:none; border-left:none; border-right:none; }
    .tab:hover { color:var(--text); }
    .tab.active { color:var(--accent); border-bottom-color:var(--accent); }

    /* Forms */
    .form-panel { display:none; }
    .form-panel.active { display:block; }
    .form-group { margin-bottom:16px; }
    .form-label { display:block; font-family:var(--font-mono); font-size:11px; color:var(--muted); letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
    .form-input, .form-textarea, .form-select {
      width:100%; padding:10px 14px; background:var(--bg2); border:1px solid var(--border);
      border-radius:8px; color:var(--text); font-family:var(--font-body); font-size:14px; outline:none;
    }
    .form-input:focus, .form-textarea:focus, .form-select:focus { border-color:var(--accent); }
    .form-textarea { min-height:200px; resize:vertical; font-family:var(--font-mono); font-size:13px; }
    .form-select { appearance:none; cursor:pointer; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .form-row-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
    .form-checkbox { display:flex; align-items:center; gap:8px; cursor:pointer; }
    .form-checkbox input { accent-color:var(--accent); width:16px; height:16px; cursor:pointer; }
    .form-checkbox span { font-size:13px; color:var(--muted); }
    .form-help { font-size:11px; color:var(--muted); margin-top:4px; font-style:italic; }

    .submit-btn {
      margin-top:20px; padding:12px 32px; background:var(--accent); color:var(--bg); border:none;
      border-radius:8px; font-family:var(--font-mono); font-size:13px; cursor:pointer; font-weight:500;
    }
    .submit-btn:hover { opacity:0.9; }
    .submit-btn:disabled { opacity:0.5; cursor:not-allowed; }

    /* Toast */
    .toast { position:fixed; top:20px; right:20px; padding:14px 20px; border-radius:8px; font-family:var(--font-mono); font-size:12px; z-index:1000; display:none; animation:slideIn .3s ease; }
    .toast--success { background:var(--success); color:#000; }
    .toast--error { background:var(--danger); color:#fff; }
    @keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }

    /* Recent entries */
    .recent { margin-top:2rem; padding-top:1rem; border-top:1px solid var(--border); }
    .recent__title { font-family:var(--font-mono); font-size:11px; color:var(--muted); letter-spacing:2px; margin-bottom:12px; }
    .recent__item { padding:8px 0; border-bottom:1px solid var(--border); font-size:13px; display:flex; justify-content:space-between; }
    .recent__item span { color:var(--muted); font-family:var(--font-mono); font-size:10px; }

    /* Token input */
    .token-section { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:16px 20px; margin-bottom:2rem; }
    .token-section summary { font-family:var(--font-mono); font-size:12px; color:var(--warning); cursor:pointer; }
    .token-section .form-input { margin-top:10px; font-size:12px; letter-spacing:0; }
    .token-help { font-size:11px; color:var(--muted); margin-top:8px; line-height:1.5; }

    @media(max-width:600px) {
      .form-row, .form-row-3 { grid-template-columns:1fr; }
      .login__box { width:90%; padding:24px; }
    }
  </style>
</head>
<body>

<!-- Toast notification -->
<div class="toast" id="toast"></div>

<!-- Login screen -->
<div class="login" id="login-screen">
  <div class="login__box">
    <div class="login__logo"><span>{</span>TC<span>}</span> admin</div>
    <p class="login__sub">Enter your PIN to access the admin panel</p>
    <input type="password" class="login__input" id="pin-input" maxlength="4" placeholder="····" autofocus />
    <button class="login__btn" id="pin-submit">Unlock →</button>
    <p class="login__error" id="pin-error">Incorrect PIN. Try again.</p>
  </div>
</div>

<!-- Admin panel -->
<div class="admin" id="admin-panel">
  <div class="admin__header">
    <div class="admin__title">// admin panel</div>
    <button class="admin__logout" id="logout-btn">logout</button>
  </div>

  <!-- GitHub token -->
  <details class="token-section">
    <summary>⚙ GitHub Token (required for publishing)</summary>
    <input type="password" class="form-input" id="github-token" placeholder="ghp_xxxxxxxxxxxx or github_pat_xxxx" />
    <p class="token-help">Your GitHub Personal Access Token with <code>repo</code> scope. This is stored only in your browser session — never sent anywhere except GitHub's API.</p>
  </details>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab active" data-tab="cert">Certifications</button>
    <button class="tab" data-tab="project">Projects</button>
    <button class="tab" data-tab="blog">Blog Posts</button>
    <button class="tab" data-tab="note">Daily Notes</button>
  </div>

  <!-- Certification Form -->
  <div class="form-panel active" id="panel-cert">
    <div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="cert-title" placeholder="AWS Cloud Practitioner" /></div>
    <div class="form-group"><label class="form-label">Description</label><input class="form-input" id="cert-description" placeholder="One-line summary of the certification" /></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Issuer *</label><input class="form-input" id="cert-issuer" placeholder="Amazon Web Services" /></div>
      <div class="form-group"><label class="form-label">Date *</label><input class="form-input" id="cert-date" type="date" /></div>
    </div>
    <div class="form-row-3">
      <div class="form-group">
        <label class="form-label">Size *</label>
        <select class="form-select" id="cert-size"><option value="major">Major</option><option value="minor">Minor</option></select>
      </div>
      <div class="form-group"><label class="form-label">Credential ID</label><input class="form-input" id="cert-credentialId" placeholder="ABC-123" /></div>
      <div class="form-group"><label class="form-label">Credential URL</label><input class="form-input" id="cert-credentialUrl" placeholder="https://credly.com/..." /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Tags (comma separated)</label><input class="form-input" id="cert-tags" placeholder="AWS, Cloud, ML" /></div>
      <div class="form-group"><label class="form-label">Badge Image Path</label><input class="form-input" id="cert-image" placeholder="/certs/my-badge.png" /></div>
    </div>
    <div class="form-group">
      <label class="form-checkbox"><input type="checkbox" id="cert-showOnHome" checked /><span>Show on homepage</span></label>
    </div>
    <div class="form-group"><label class="form-label">Content (markdown, optional)</label><textarea class="form-textarea" id="cert-content" placeholder="Write additional details about this certification..."></textarea></div>
    <button class="submit-btn" onclick="submitCert()">Publish Certification →</button>
  </div>

  <!-- Project Form -->
  <div class="form-panel" id="panel-project">
    <div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="project-title" placeholder="My Awesome Project" /></div>
    <div class="form-group"><label class="form-label">Description *</label><input class="form-input" id="project-description" placeholder="A short description of the project" /></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Date *</label><input class="form-input" id="project-date" type="date" /></div>
      <div class="form-group"><label class="form-label">Tags * (comma separated)</label><input class="form-input" id="project-tags" placeholder="React, TypeScript, API" /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">GitHub URL</label><input class="form-input" id="project-github" placeholder="https://github.com/tejansree21/..." /></div>
      <div class="form-group"><label class="form-label">Live URL</label><input class="form-input" id="project-live" placeholder="https://myproject.vercel.app" /></div>
    </div>
    <div class="form-group">
      <label class="form-checkbox"><input type="checkbox" id="project-featured" /><span>Featured project (shown prominently)</span></label>
    </div>
    <div class="form-group"><label class="form-label">Content * (markdown)</label><textarea class="form-textarea" id="project-content" placeholder="## Overview&#10;&#10;Write about your project here..."></textarea></div>
    <button class="submit-btn" onclick="submitProject()">Publish Project →</button>
  </div>

  <!-- Blog Form -->
  <div class="form-panel" id="panel-blog">
    <div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="blog-title" placeholder="My Blog Post Title" /></div>
    <div class="form-group"><label class="form-label">Description *</label><input class="form-input" id="blog-description" placeholder="What this post is about" /></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Date *</label><input class="form-input" id="blog-date" type="date" /></div>
      <div class="form-group"><label class="form-label">Tags (comma separated)</label><input class="form-input" id="blog-tags" placeholder="tutorial, typescript" /></div>
    </div>
    <div class="form-group">
      <label class="form-checkbox"><input type="checkbox" id="blog-draft" /><span>Save as draft (won't be published)</span></label>
    </div>
    <div class="form-group"><label class="form-label">Content * (markdown)</label><textarea class="form-textarea" id="blog-content" placeholder="Write your blog post in markdown..." style="min-height:300px"></textarea></div>
    <button class="submit-btn" onclick="submitBlog()">Publish Post →</button>
  </div>

  <!-- Note Form -->
  <div class="form-panel" id="panel-note">
    <div class="form-group"><label class="form-label">Title / Summary *</label><input class="form-input" id="note-title" placeholder="TIL: Something cool I learned today" /></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Date *</label><input class="form-input" id="note-date" type="date" /></div>
      <div class="form-group"><label class="form-label">Tags (comma separated)</label><input class="form-input" id="note-tags" placeholder="til, astro" /></div>
    </div>
    <div class="form-group"><label class="form-label">Content * (markdown)</label><textarea class="form-textarea" id="note-content" placeholder="Write your daily note..."></textarea></div>
    <button class="submit-btn" onclick="submitNote()">Publish Note →</button>
  </div>
</div>

<script is:inline>
  const PIN = '2903';
  const REPO = 'tejansree21/tejansree21.github.io';

  // --- Auth ---
  document.getElementById('pin-submit').addEventListener('click', checkPin);
  document.getElementById('pin-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') checkPin(); });

  function checkPin() {
    const val = document.getElementById('pin-input').value;
    if (val === PIN) {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('admin-panel').style.display = 'block';
      // Set today's date as default
      const today = new Date().toISOString().split('T')[0];
      document.querySelectorAll('input[type="date"]').forEach(el => el.value = today);
    } else {
      document.getElementById('pin-error').style.display = 'block';
      document.getElementById('pin-input').value = '';
      document.getElementById('pin-input').focus();
    }
  }

  document.getElementById('logout-btn').addEventListener('click', () => {
    document.getElementById('admin-panel').style.display = 'none';
    document.getElementById('login-screen').style.display = 'flex';
    document.getElementById('pin-input').value = '';
    document.getElementById('pin-error').style.display = 'none';
  });

  // --- Tabs ---
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.form-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('panel-' + tab.dataset.tab).classList.add('active');
    });
  });

  // --- Toast ---
  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.className = 'toast toast--' + type;
    toast.style.display = 'block';
    setTimeout(() => { toast.style.display = 'none'; }, 4000);
  }

  // --- GitHub API ---
  function getToken() {
    const t = document.getElementById('github-token').value.trim();
    if (!t) { showToast('Please enter your GitHub token first', 'error'); return null; }
    return t;
  }

  function slugify(text) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  function parseTags(str) {
    return str.split(',').map(t => t.trim()).filter(Boolean);
  }

  async function commitFile(path, content, message) {
    const token = getToken();
    if (!token) return false;

    const url = `https://api.github.com/repos/${REPO}/contents/${path}`;
    const body = {
      message: message,
      content: btoa(unescape(encodeURIComponent(content))),
      branch: 'main'
    };

    try {
      const res = await fetch(url, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        showToast('Published! Vercel will auto-deploy in ~30s.', 'success');
        return true;
      } else {
        const err = await res.json();
        showToast('Error: ' + (err.message || 'Failed to publish'), 'error');
        return false;
      }
    } catch (e) {
      showToast('Network error: ' + e.message, 'error');
      return false;
    }
  }

  // --- Submissions ---
  async function submitCert() {
    const title = document.getElementById('cert-title').value.trim();
    const issuer = document.getElementById('cert-issuer').value.trim();
    const date = document.getElementById('cert-date').value;
    if (!title || !issuer || !date) { showToast('Fill in required fields (Title, Issuer, Date)', 'error'); return; }

    const desc = document.getElementById('cert-description').value.trim();
    const size = document.getElementById('cert-size').value;
    const credId = document.getElementById('cert-credentialId').value.trim();
    const credUrl = document.getElementById('cert-credentialUrl').value.trim();
    const tags = parseTags(document.getElementById('cert-tags').value);
    const image = document.getElementById('cert-image').value.trim();
    const showOnHome = document.getElementById('cert-showOnHome').checked;
    const content = document.getElementById('cert-content').value.trim();

    let frontmatter = `---\ntitle: "${title}"\n`;
    if (desc) frontmatter += `description: "${desc}"\n`;
    frontmatter += `issuer: "${issuer}"\ndate: ${date}\nsize: ${size}\nshowOnHome: ${showOnHome}\n`;
    if (credId) frontmatter += `credentialId: "${credId}"\n`;
    if (credUrl) frontmatter += `credentialUrl: "${credUrl}"\n`;
    if (tags.length) frontmatter += `tags: [${tags.map(t => `"${t}"`).join(', ')}]\n`;
    if (image) frontmatter += `image: "${image}"\n`;
    frontmatter += `---\n\n${content || ''}`;

    const slug = slugify(title);
    const ok = await commitFile(`src/content/certifications/${slug}.md`, frontmatter, `Add cert: ${title}`);
    if (ok) { document.getElementById('cert-title').value = ''; document.getElementById('cert-description').value = ''; document.getElementById('cert-issuer').value = ''; document.getElementById('cert-credentialId').value = ''; document.getElementById('cert-credentialUrl').value = ''; document.getElementById('cert-tags').value = ''; document.getElementById('cert-image').value = ''; document.getElementById('cert-content').value = ''; }
  }

  async function submitProject() {
    const title = document.getElementById('project-title').value.trim();
    const desc = document.getElementById('project-description').value.trim();
    const date = document.getElementById('project-date').value;
    const tags = parseTags(document.getElementById('project-tags').value);
    if (!title || !desc || !date || !tags.length) { showToast('Fill in required fields', 'error'); return; }

    const github = document.getElementById('project-github').value.trim();
    const live = document.getElementById('project-live').value.trim();
    const featured = document.getElementById('project-featured').checked;
    const content = document.getElementById('project-content').value.trim();

    let fm = `---\ntitle: "${title}"\ndescription: "${desc}"\ntags: [${tags.map(t => `"${t}"`).join(', ')}]\nfeatured: ${featured}\ndate: ${date}\n`;
    if (github) fm += `github: "${github}"\n`;
    if (live) fm += `live: "${live}"\n`;
    fm += `---\n\n${content || ''}`;

    const slug = slugify(title);
    const ok = await commitFile(`src/content/projects/${slug}.md`, fm, `Add project: ${title}`);
    if (ok) { document.getElementById('project-title').value = ''; document.getElementById('project-description').value = ''; document.getElementById('project-tags').value = ''; document.getElementById('project-github').value = ''; document.getElementById('project-live').value = ''; document.getElementById('project-content').value = ''; }
  }

  async function submitBlog() {
    const title = document.getElementById('blog-title').value.trim();
    const desc = document.getElementById('blog-description').value.trim();
    const date = document.getElementById('blog-date').value;
    const tags = parseTags(document.getElementById('blog-tags').value);
    const draft = document.getElementById('blog-draft').checked;
    const content = document.getElementById('blog-content').value.trim();
    if (!title || !desc || !date || !content) { showToast('Fill in required fields', 'error'); return; }

    let fm = `---\ntitle: "${title}"\ndescription: "${desc}"\ndate: ${date}\ntags: [${tags.map(t => `"${t}"`).join(', ')}]\ndraft: ${draft}\n---\n\n${content}`;

    const slug = slugify(title);
    const ok = await commitFile(`src/content/blog/${slug}.md`, fm, `Add post: ${title}`);
    if (ok) { document.getElementById('blog-title').value = ''; document.getElementById('blog-description').value = ''; document.getElementById('blog-tags').value = ''; document.getElementById('blog-content').value = ''; }
  }

  async function submitNote() {
    const title = document.getElementById('note-title').value.trim();
    const date = document.getElementById('note-date').value;
    const tags = parseTags(document.getElementById('note-tags').value);
    const content = document.getElementById('note-content').value.trim();
    if (!title || !date || !content) { showToast('Fill in required fields', 'error'); return; }

    let fm = `---\ntitle: "${title}"\ndate: ${date}\ntags: [${tags.map(t => `"${t}"`).join(', ')}]\n---\n\n${content}`;

    const ok = await commitFile(`src/content/notes/${date}.md`, fm, `Add note: ${date}`);
    if (ok) { document.getElementById('note-title').value = ''; document.getElementById('note-tags').value = ''; document.getElementById('note-content').value = ''; }
  }
</script>

</body>
</html>
